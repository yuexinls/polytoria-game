[input_devices]

pointing/android/enable_pan_and_scale_gestures=true

[layer_names]

3d_render/layer_6="Character"

[physics]

2d/physics_engine="Dummy"
3d/physics_engine="Jolt Physics"
jolt_physics_3d/simulation/generate_all_kinematic_contacts=true
jolt_physics_3d/limits/max_bodies=131070
3d/default_gravity=17.0

[rendering]

occlusion_culling/bvh_build_quality=0
textures/canvas_textures/default_texture_filter=2
rendering_device/driver.windows="d3d12"
textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/size.mobile=512
reflections/sky_reflections/ggx_samples.mobile=2
anti_aliasing/quality/msaa_3d=2
limits/global_shader_variables/buffer_size=524288
environment/defaults/default_clear_color=Color(0.15, 0.15, 0.15, 1)
occlusion_culling/use_occlusion_culling=true
mesh_lod/lod_change/threshold_pixels=0.0
lights_and_shadows/positional_shadow/atlas_size.mobile=512
