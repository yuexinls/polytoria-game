; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[DebugGUI]

Settings/enableGraphs=true
Settings/enableLogs=true
Settings/backgroundColor=Color(0, 0, 0, 0.7)
Settings/scrubberColor=Color(1, 1, 0, 0.7)
Settings/graphWidth=300
Settings/graphHeight=100
Settings/temporaryLogLifetime=5.0

[accessibility]

general/accessibility_support=2

[animation]

warnings/check_invalid_track_paths=false

[application]

config/name="Polytoria"
config/version="2.0.6"
run/main_scene="uid://c2tql65t73ak5"
config/use_custom_user_dir=true
config/custom_user_dir_name="PolytoriaClient"
config/quit_on_go_back=false
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
run/flush_stdout_on_print=true
boot_splash/bg_color=Color(0.09803922, 0.09803922, 0.09803922, 1)
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false
boot_splash/image="uid://ngfx6aps7f0g"
config/icon="uid://bvolad7rptrsm"

[autoload]

Globals="*res://scripts/shared/Globals.cs"
AssetLoader="*uid://rdicloyxgx18"
WebAssetLoader="*uid://0g13so6g55p0"
AppCloseDimmer="*res://scripts/shared/AppCloseDimmer.cs"

[display]

window/subwindows/embed_subwindows=false
window/handheld/orientation=1
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Polytoria"
project/solution_directory="../"

[editor_plugins]

enabled=PackedStringArray("res://addons/DeeplinkPlugin/plugin.cfg", "res://addons/PolytoriaExportPlugin/plugin.cfg")

[gui]

common/snap_controls_to_pixels=false
common/show_focus_state_on_pointer_event=2
theme/custom="uid://cwykhfx1ffjoj"
theme/custom_font="uid://c4ad5x0dhckrv"

